# =====================================================================
# .env.production.example — template for NON-Docker VPS deploy
# (Node runs on host; Postgres/Redis in Docker on loopback)
#
# Copy on the server (never commit the real file):
#   cp .env.production.example .env.production
#   nano .env.production
# =====================================================================

NODE_ENV=production
PORT=3000
APP_NAME=Hisab247
GLOBAL_API_PREFIX=api/v1
CORS_ORIGINS=https://hisab247.com,https://www.hisab247.com,https://app.hisab247.com
ENABLE_SWAGGER=false

# Host-process model: DB/Redis published to 127.0.0.1 by docker-compose
DATABASE_URL=postgresql://hisab247:CHANGE_ME@127.0.0.1:5432/hisab247?schema=public&connection_limit=20

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0
REDIS_KEY_PREFIX=hisab247:

JWT_SECRET=CHANGE_ME_min_32_chars_match_nextauth
JWT_ALGORITHM=HS256
JWT_ISSUER=hisab247-frontend
JWT_AUDIENCE=hisab247-backend

RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120
CACHE_TTL_DASHBOARD=60
CACHE_TTL_FINANCE_SUMMARY=120
CACHE_TTL_USER=300

# Optional: enable POST /api/v1/admin/seed with X-Seed-Secret header
# SEED_SECRET=
