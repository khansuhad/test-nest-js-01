# =====================================================================
# .env.docker.example — VPS / production Docker mode
# Used with docker-compose.prod.yml. Hostnames are compose service names.
#
# Usage (on VPS):
#   cp .env.docker.example .env.docker
#   nano .env.docker
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.docker up -d --build
# =====================================================================

# --- Compose / infrastructure (read by docker-compose.prod.yml) ---
POSTGRES_USER=hisab247
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=hisab247
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- App ---
NODE_ENV=production
PORT=3000
APP_NAME=Hisab247
GLOBAL_API_PREFIX=api/v1
CORS_ORIGINS=https://hisab247.com,https://www.hisab247.com,https://app.hisab247.com
ENABLE_SWAGGER=false

# DATABASE_URL is built automatically in docker-compose.prod.yml from POSTGRES_*.
# You can leave this commented out on VPS:
# DATABASE_URL=postgresql://hisab247:CHANGE_ME@postgres:5432/hisab247?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=hisab247:

# --- JWT (must match NextAuth on the frontend) ---
JWT_SECRET=CHANGE_ME_min_32_chars_same_as_nextauth
JWT_ALGORITHM=HS256
JWT_ISSUER=hisab247-frontend
JWT_AUDIENCE=hisab247-backend

# --- Production safety ---
# false = do not insert test data on every container restart
RUN_DB_SEED=false

# Optional: call POST /api/v1/admin/seed with header X-Seed-Secret
# SEED_SECRET=

RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120
CACHE_TTL_DASHBOARD=60
CACHE_TTL_FINANCE_SUMMARY=120
CACHE_TTL_USER=300
