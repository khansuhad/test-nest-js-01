# =====================================================================
# .env.docker.example — DOCKER mode
# Used by docker-compose for the `backend` container. Hostnames refer
# to docker-compose service names (not localhost).
#
# Usage:
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up --build
# =====================================================================

# --- App ---
NODE_ENV=production
PORT=3000
APP_NAME=Hisab247
GLOBAL_API_PREFIX=api/v1
CORS_ORIGINS=*

# --- PostgreSQL ---
# Hostname `postgres` is the docker-compose SERVICE name (DNS inside the network).
DATABASE_URL=postgresql://hisab247:hisab247@postgres:5432/hisab247?schema=public

# --- Redis ---
# Hostname `redis` is the docker-compose SERVICE name.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=hisab247:

# --- JWT (must match NextAuth) ---
JWT_SECRET=replace-with-shared-secret-from-nextauth
JWT_ALGORITHM=HS256
JWT_ISSUER=hisab247-frontend
JWT_AUDIENCE=hisab247-backend

# --- Rate limiting ---
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120

# --- Cache TTLs (seconds) ---
CACHE_TTL_DASHBOARD=60
CACHE_TTL_FINANCE_SUMMARY=120
CACHE_TTL_USER=300
