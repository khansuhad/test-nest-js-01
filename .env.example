# =====================================================================
# .env.example — LOCAL DEVELOPMENT mode
# Copy this file to `.env` (already done if you cloned with .env) and
# adjust JWT_SECRET. This file assumes:
#   - You run Postgres + Redis on your HOST machine (or expose them
#     from Docker via `docker compose up -d postgres redis`).
#   - You run NestJS via `npm run start:dev` on the host.
# For DOCKER-only mode see `.env.docker.example`.
# =====================================================================

# --- App ---
NODE_ENV=development
PORT=3000
APP_NAME=Hisab247
GLOBAL_API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- PostgreSQL (Prisma) ---
# Hostname is `localhost` because Prisma + NestJS run on the host.
DATABASE_URL=postgresql://hisab247:hisab247@localhost:5432/hisab247?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=hisab247:

# --- JWT (verification only — token is issued by NextAuth on frontend) ---
# For LOCAL DEV: any 32+ char string works. For PROD: must match NextAuth's secret.
JWT_SECRET=local-dev-secret-change-me-please-32chars-min
JWT_ALGORITHM=HS256
JWT_ISSUER=hisab247-frontend
JWT_AUDIENCE=hisab247-backend

# --- Rate limiting ---
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120

# --- Cache TTLs (seconds) ---
CACHE_TTL_DASHBOARD=60
CACHE_TTL_FINANCE_SUMMARY=120
CACHE_TTL_USER=300
